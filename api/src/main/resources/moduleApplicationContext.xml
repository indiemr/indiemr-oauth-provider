<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-3.0.xsd">

	<context:component-scan base-package="org.openmrs.module.indiemroauthprovider.provider" />
	<context:component-scan base-package="org.openmrs.module.indiemroauthprovider.crypto" />
	<context:component-scan base-package="org.openmrs.module.indiemroauthprovider.util" />

	<bean id="indiemroauthprovider.OAuthAccountDao"
	      class="org.openmrs.module.indiemroauthprovider.dao.impl.OAuthAccountDaoImpl">
		<property name="sessionFactory" ref="dbSessionFactory" />
	</bean>

	<bean id="indiemroauthprovider.OAuthProviderDao"
	      class="org.openmrs.module.indiemroauthprovider.dao.impl.OAuthProviderDaoImpl">
		<property name="sessionFactory" ref="dbSessionFactory" />
	</bean>

	<bean id="indiemroauthprovider.OAuthCapabilityDao"
	      class="org.openmrs.module.indiemroauthprovider.dao.impl.OAuthCapabilityDaoImpl">
		<property name="sessionFactory" ref="dbSessionFactory" />
	</bean>

	<bean id="indiemroauthprovider.ExternalResourceMappingDao"
	      class="org.openmrs.module.indiemroauthprovider.dao.impl.ExternalResourceMappingDaoImpl">
		<property name="sessionFactory" ref="dbSessionFactory" />
	</bean>

	<bean id="indiemroauthprovider.TeleconsultLinkDao"
	      class="org.openmrs.module.indiemroauthprovider.dao.impl.TeleconsultLinkDaoImpl">
		<property name="sessionFactory" ref="dbSessionFactory" />
	</bean>

	<bean id="indiemroauthprovider.OAuthConnectService"
	      class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
		<property name="transactionManager" ref="transactionManager" />
		<property name="preInterceptors" ref="serviceInterceptors" />
		<property name="transactionAttributeSource" ref="transactionAttributeSource" />
		<property name="target">
			<bean class="org.openmrs.module.indiemroauthprovider.api.impl.OAuthConnectServiceImpl">
				<property name="oauthRegistry" ref="indiemroauthprovider.OAuthProviderRegistry" />
				<property name="oauthProviderDao" ref="indiemroauthprovider.OAuthProviderDao" />
				<property name="oauthAccountDao" ref="indiemroauthprovider.OAuthAccountDao" />
				<property name="crypto" ref="indiemroauthprovider.CryptoService" />
			</bean>
		</property>
	</bean>

	<bean id="indiemroauthprovider.ExternalResourceService"
	      class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
		<property name="transactionManager" ref="transactionManager" />
		<property name="preInterceptors" ref="serviceInterceptors" />
		<property name="transactionAttributeSource" ref="transactionAttributeSource" />
		<property name="target">
			<bean class="org.openmrs.module.indiemroauthprovider.api.impl.ExternalResourceServiceImpl">
				<property name="mappingDao" ref="indiemroauthprovider.ExternalResourceMappingDao" />
				<property name="calendarRegistry" ref="indiemroauthprovider.CalendarProviderRegistry" />
				<property name="meetingRegistry" ref="indiemroauthprovider.MeetingProviderRegistry" />
				<property name="teleconsultLinkDao" ref="indiemroauthprovider.TeleconsultLinkDao" />
				<property name="crypto" ref="indiemroauthprovider.CryptoService" />
			</bean>
		</property>
	</bean>

	<bean id="indiemroauthprovider.TeleconsultService"
	      class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
		<property name="transactionManager" ref="transactionManager" />
		<property name="preInterceptors" ref="serviceInterceptors" />
		<property name="transactionAttributeSource" ref="transactionAttributeSource" />
		<property name="target">
			<bean class="org.openmrs.module.indiemroauthprovider.api.impl.TeleconsultServiceImpl">
				<property name="meetingRegistry" ref="indiemroauthprovider.MeetingProviderRegistry" />
				<property name="oauthAccountDao" ref="indiemroauthprovider.OAuthAccountDao" />
				<property name="externalResourceMappingDao" ref="indiemroauthprovider.ExternalResourceMappingDao" />
				<property name="teleconsultLinkDao" ref="indiemroauthprovider.TeleconsultLinkDao" />
				<property name="crypto" ref="indiemroauthprovider.CryptoService" />
				<property name="moduleConfig" ref="indiemroauthprovider.ModuleConfig" />
				<property name="calendarRegistry" ref="indiemroauthprovider.CalendarProviderRegistry" />
				<property name="externalResourceService" ref="indiemroauthprovider.ExternalResourceService" />
			</bean>
		</property>
	</bean>

	<bean parent="serviceContext">
		<property name="moduleService">
			<list merge="true">
				<value>org.openmrs.module.indiemroauthprovider.api.OAuthConnectService</value>
				<ref bean="indiemroauthprovider.OAuthConnectService" />
			</list>
		</property>
	</bean>

	<bean parent="serviceContext">
		<property name="moduleService">
			<list merge="true">
				<value>org.openmrs.module.indiemroauthprovider.api.ExternalResourceService</value>
				<ref bean="indiemroauthprovider.ExternalResourceService" />
			</list>
		</property>
	</bean>

	<bean parent="serviceContext">
		<property name="moduleService">
			<list merge="true">
				<value>org.openmrs.module.indiemroauthprovider.api.TeleconsultService</value>
				<ref bean="indiemroauthprovider.TeleconsultService" />
			</list>
		</property>
	</bean>

</beans>
