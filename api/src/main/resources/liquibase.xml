<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-2.0.xsd">

	<changeSet id="indiemroauthprovider-2026-07-02-001" author="indiemr">
		<comment>Create indiemr_oauth_provider table</comment>
		<createTable tableName="indiemr_oauth_provider">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="code" type="varchar(50)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="display" type="varchar(255)">
				<constraints nullable="false" />
			</column>
			<column name="authorization_url" type="varchar(2048)" />
			<column name="token_url" type="varchar(2048)" />
			<column name="userinfo_url" type="varchar(2048)" />
			<column name="revocation_url" type="varchar(2048)" />
			<column name="supports_refresh_token" type="boolean" defaultValueBoolean="true">
				<constraints nullable="false" />
			</column>
			<column name="supports_pkce" type="boolean" defaultValueBoolean="true">
				<constraints nullable="false" />
			</column>
			<column name="enabled" type="boolean" defaultValueBoolean="true">
				<constraints nullable="false" />
			</column>
			<column name="metadata_json" type="text" />
			<column name="created_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="updated_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>

	<changeSet id="indiemroauthprovider-2026-07-02-002" author="indiemr">
		<comment>Create indiemr_oauth_capability table</comment>
		<createTable tableName="indiemr_oauth_capability">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="code" type="varchar(50)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="display" type="varchar(255)">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>

	<changeSet id="indiemroauthprovider-2026-07-02-003" author="indiemr">
		<comment>Create indiemr_oauth_account table</comment>
		<createTable tableName="indiemr_oauth_account">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="provider_uuid" type="varchar(38)">
				<constraints nullable="false" />
			</column>
			<column name="oauth_provider_id" type="bigint">
				<constraints nullable="false" />
			</column>
			<column name="external_account_id" type="varchar(255)" />
			<column name="external_email" type="varchar(255)" />
			<column name="display" type="varchar(255)" />
			<column name="access_token_enc" type="text" />
			<column name="refresh_token_enc" type="text" />
			<column name="id_token_enc" type="text" />
			<column name="scope" type="varchar(1024)" />
			<column name="expires_at" type="datetime" />
			<column name="status" type="varchar(32)" defaultValue="ACTIVE">
				<constraints nullable="false" />
			</column>
			<column name="metadata_json" type="text" />
			<column name="voided" type="boolean" defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="created_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="updated_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_oauth_account_provider"
		    baseTableName="indiemr_oauth_account"
		    baseColumnNames="provider_uuid"
		    referencedTableName="provider"
		    referencedColumnNames="uuid" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_oauth_account_oauth_provider"
		    baseTableName="indiemr_oauth_account"
		    baseColumnNames="oauth_provider_id"
		    referencedTableName="indiemr_oauth_provider"
		    referencedColumnNames="id" />

		<addUniqueConstraint
		    constraintName="uk_indiemr_oauth_account_provider_external"
		    tableName="indiemr_oauth_account"
		    columnNames="provider_uuid, oauth_provider_id, external_account_id" />

		<createIndex indexName="idx_indiemr_oauth_account_provider" tableName="indiemr_oauth_account">
			<column name="provider_uuid" />
		</createIndex>
	</changeSet>

	<changeSet id="indiemroauthprovider-2026-07-02-004" author="indiemr">
		<comment>Create indiemr_oauth_account_capability table</comment>
		<createTable tableName="indiemr_oauth_account_capability">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="oauth_account_id" type="bigint">
				<constraints nullable="false" />
			</column>
			<column name="capability_id" type="bigint">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_oauth_acct_cap_account"
		    baseTableName="indiemr_oauth_account_capability"
		    baseColumnNames="oauth_account_id"
		    referencedTableName="indiemr_oauth_account"
		    referencedColumnNames="id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_oauth_acct_cap_capability"
		    baseTableName="indiemr_oauth_account_capability"
		    baseColumnNames="capability_id"
		    referencedTableName="indiemr_oauth_capability"
		    referencedColumnNames="id" />

		<addUniqueConstraint
		    constraintName="uk_indiemr_oauth_account_capability"
		    tableName="indiemr_oauth_account_capability"
		    columnNames="oauth_account_id, capability_id" />
	</changeSet>

	<changeSet id="indiemroauthprovider-2026-07-02-005" author="indiemr">
		<comment>Create external event tables</comment>
		<createTable tableName="indiemr_external_event">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints nullable="false" primaryKey="true" />
			</column>
			<column name="uuid" type="char(38)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="oauth_account_id" type="bigint">
				<constraints nullable="false" />
			</column>
			<column name="external_resource_type" type="varchar(64)">
				<constraints nullable="false" />
			</column>
			<column name="external_event_id" type="varchar(512)">
				<constraints nullable="false" />
			</column>
			<column name="status" type="varchar(20)" defaultValue="active">
				<constraints nullable="false" />
			</column>
			<column name="metadata_json" type="text" />
			<column name="creator" type="int">
				<constraints nullable="false" />
			</column>
			<column name="date_created" type="datetime">
				<constraints nullable="false" />
			</column>
			<column name="changed_by" type="int" />
			<column name="date_changed" type="datetime" />
			<column name="voided" type="boolean" defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="voided_by" type="int" />
			<column name="date_voided" type="datetime" />
			<column name="void_reason" type="varchar(255)" />
		</createTable>

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_external_event_account"
		    baseTableName="indiemr_external_event"
		    baseColumnNames="oauth_account_id"
		    referencedTableName="indiemr_oauth_account"
		    referencedColumnNames="id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_external_event_creator"
		    baseTableName="indiemr_external_event"
		    baseColumnNames="creator"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_external_event_changed_by"
		    baseTableName="indiemr_external_event"
		    baseColumnNames="changed_by"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_external_event_voided_by"
		    baseTableName="indiemr_external_event"
		    baseColumnNames="voided_by"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<createIndex tableName="indiemr_external_event" indexName="idx_indiemr_external_event_resource_type">
			<column name="external_resource_type" />
		</createIndex>

		<createTable tableName="indiemr_resource_event_mapping">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="uuid" type="char(38)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="external_event_id" type="bigint">
				<constraints nullable="false" />
			</column>
			<column name="internal_resource_type" type="varchar(64)">
				<constraints nullable="false" />
			</column>
			<column name="internal_resource_uuid" type="varchar(64)">
				<constraints nullable="false" />
			</column>
			<column name="creator" type="int">
				<constraints nullable="false" />
			</column>
			<column name="date_created" type="datetime">
				<constraints nullable="false" />
			</column>
			<column name="voided" type="boolean" defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="changed_by" type="int" />
			<column name="date_changed" type="datetime" />
			<column name="voided_by" type="int" />
			<column name="date_voided" type="datetime" />
			<column name="void_reason" type="varchar(255)" />
		</createTable>

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_res_event_mapping_event"
		    baseTableName="indiemr_resource_event_mapping"
		    baseColumnNames="external_event_id"
		    referencedTableName="indiemr_external_event"
		    referencedColumnNames="id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_res_event_mapping_creator"
		    baseTableName="indiemr_resource_event_mapping"
		    baseColumnNames="creator"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_res_event_mapping_voided_by"
		    baseTableName="indiemr_resource_event_mapping"
		    baseColumnNames="voided_by"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />
		
		<addForeignKeyConstraint
			constraintName="fk_indiemr_res_event_mapping_changed_by"
			baseTableName="indiemr_resource_event_mapping"
			baseColumnNames="changed_by"
			referencedTableName="users"
			referencedColumnNames="user_id" />

		<createIndex indexName="idx_indiemr_res_event_internal" tableName="indiemr_resource_event_mapping">
			<column name="internal_resource_type" />
			<column name="internal_resource_uuid" />
		</createIndex>
	</changeSet>

	<changeSet id="indiemroauthprovider-2026-07-02-006" author="indiemr">
		<comment>Create indiemr_meeting table</comment>
		<createTable tableName="indiemr_meeting">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="uuid" type="char(38)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="external_event_id" type="bigint">
				<constraints nullable="false" />
			</column>
			<column name="token" type="varchar(64)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="meeting_url" type="varchar(2048)">
				<constraints nullable="false" />
			</column>
			<column name="status" type="varchar(20)" defaultValue="created">
				<constraints nullable="false" />
			</column>
			<column name="expires_at" type="datetime">
				<constraints nullable="false" />
			</column>
			<column name="creator" type="int">
				<constraints nullable="false" />
			</column>
			<column name="date_created" type="datetime">
				<constraints nullable="false" />
			</column>
			<column name="changed_by" type="int" />
			<column name="date_changed" type="datetime" />
			<column name="voided" type="boolean" defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="voided_by" type="int" />
			<column name="date_voided" type="datetime" />
			<column name="void_reason" type="varchar(255)" />
		</createTable>

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_meeting_external_event"
		    baseTableName="indiemr_meeting"
		    baseColumnNames="external_event_id"
		    referencedTableName="indiemr_external_event"
		    referencedColumnNames="id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_meeting_creator"
		    baseTableName="indiemr_meeting"
		    baseColumnNames="creator"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_meeting_changed_by"
		    baseTableName="indiemr_meeting"
		    baseColumnNames="changed_by"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<addForeignKeyConstraint
		    constraintName="fk_indiemr_meeting_voided_by"
		    baseTableName="indiemr_meeting"
		    baseColumnNames="voided_by"
		    referencedTableName="users"
		    referencedColumnNames="user_id" />

		<createIndex indexName="idx_indiemr_meeting_external_event" tableName="indiemr_meeting">
			<column name="external_event_id" />
		</createIndex>
	</changeSet>

