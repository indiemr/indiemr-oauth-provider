<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="000-drop-legacy" author="indiemr">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="provider_google_token" />
        </preConditions>
        <dropTable tableName="teleconsult_link" />
        <dropTable tableName="provider_google_token" />
    </changeSet>

    <!-- oauth_provider
    id
    code
    display_name
    config... -->

    <changeSet id="001-oauth-provider" author="indiemr">
        <createTable tableName="oauth_provider">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" />
            </column>
            <column name="display_name" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="authorization_url" type="VARCHAR(2048)" />
            <column name="token_url" type="VARCHAR(2048)" />
            <column name="userinfo_url" type="VARCHAR(2048)" />
            <column name="revocation_url" type="VARCHAR(2048)" />
            <column name="supports_refresh_token" type="TINYINT(1)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="supports_pkce" type="TINYINT(1)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="TINYINT(1)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="metadata_json" type="TEXT" />
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 2. oauth_capability -->
    <changeSet id="002-oauth-capability" author="indiemr">
        <createTable tableName="oauth_capability">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" />
            </column>
            <column name="display_name" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <!-- 3. oauth_account -->
    <changeSet id="030-oauth-account" author="indiemr">
        <createTable tableName="oauth_account">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- OpenMRS provider UUID (standalone POC); later FK to openmrs.provider -->
            <column name="provider_uuid" type="VARCHAR(64)">
                <constraints nullable="false" />
            </column>

            <column name="oauth_provider_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="external_account_id" type="VARCHAR(255)" />
            <column name="external_email" type="VARCHAR(255)" />
            <column name="display_name" type="VARCHAR(255)" />
            <column name="access_token_enc" type="TEXT" />
            <column name="refresh_token_enc" type="TEXT" />
            <column name="id_token_enc" type="TEXT"/>
            <column name="scope" type="VARCHAR(1024)"/>
            <column name="expires_at" type="TIMESTAMP"/>

            <column name="status" type="VARCHAR(32)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="metadata_json" type="TEXT"/>
            <column name="voided" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint 
            baseTableName="oauth_account" 
            baseColumnNames="oauth_provider_id" 
            referencedTableName="oauth_provider" 
            referencedColumnNames="id" 
            constraintName="fk_oauth_account_provider" 
        />

        <addUniqueConstraint 
            tableName="oauth_account" 
            columnNames="provider_uuid,oauth_provider_id,external_account_id" 
            constraintName="uk_oauth_account_provider_external"
        />

        <createIndex tableName="oauth_account" indexName="idx_oauth_account_provider_uuid">
            <column name="provider_uuid"/>
        </createIndex>
    </changeSet>

    <!-- oauth_account_capability
        oauth_account_id
        capability -->

    <changeSet id="040-oauth-account-capability" author="indiemr">
        <createTable tableName="oauth_account_capability">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="oauth_account_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="capability_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
        </createTable>

        <addForeignKeyConstraint 
            baseTableName="oauth_account_capability" 
            baseColumnNames="oauth_account_id" 
            referencedTableName="oauth_account" 
            referencedColumnNames="id" 
            constraintName="fk_oauth_acct_cap_account" 
        />

        <addForeignKeyConstraint 
            baseTableName="oauth_account_capability" 
            baseColumnNames="capability_id" 
            referencedTableName="oauth_account_capability" 
            referencedColumnNames="id" 
            constraintName="fk_oauth_acct_cap_capability" 
        />

        <addUniqueConstraint 
            tableName="oauth_account_capability"
            columnNames="oauth_account_id,capability_id"
            constraintName="uk_oauth_account_capability"
        />
    </changeSet>
    
    <!-- external_resource_mapping
    oauth_account_id
    internal_resource_type
    internal_resource_uuid
    external_resource_type
    external_resource_id
    metadata_json -->
    <changeSet id="050-external-resource-mapping" author="indiemr">
        <createTable tableName="external_resource_mapping">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="oauth_account_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="internal_resource_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="internal_resource_uuid" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="external_resource_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="external_resource_id" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="metadata_json" type="TEXT"/>
            <column name="voided" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint 
            baseTableName="external_resource_mapping" 
            baseColumnNames="oauth_account_id" 
            referencedTableName="oauth_account" 
            referencedColumnNames="id" 
            constraintName="fk_ext_res_mapping_account" 
        />

        <createIndex tableName="external_resource_mapping" indexName="idx_ext_res_internal">
            <column name="internal_resource_type"/>
            <column name="internal_resource_uuid"/>
        </createIndex>
    </changeSet>

    <!-- teleconsult_link
    oauth_account_id
    external_resource_mapping_id (optional)
    meeting_url
    meeting_id
    status
    expires_at -->

    <changeSet id="060-teleconsult-link" author="indiemr">
        <createTable tableName="teleconsult_link">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="oauth_account_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="external_resource_mapping_id" type="BIGINT"/>
            <column name="token" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="meeting_id" type="VARCHAR(255)"/>
            <column name="meeting_provider" type="VARCHAR(50)"/>
            <column name="patient_name" type="VARCHAR(255)"/>
            <column name="patient_phone" type="VARCHAR(32)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="created">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="voided" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="teleconsult_link"
            baseColumnNames="oauth_account_id"
            referencedTableName="oauth_account"
            referencedColumnNames="id"
            constraintName="fk_teleconsult_link_account"/>

        <addForeignKeyConstraint
            baseTableName="teleconsult_link"
            baseColumnNames="external_resource_mapping_id"
            referencedTableName="external_resource_mapping"
            referencedColumnNames="id"
            constraintName="fk_teleconsult_link_ext_mapping"/>
    </changeSet>

    <changeSet id="061-add-meeting-url-to-teleconsult-link" author="indiemr">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="teleconsult_link" columnName="meeting_url"/>
            </not>
        </preConditions>
        <addColumn tableName="teleconsult_link">
            <column name="meeting_url" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>